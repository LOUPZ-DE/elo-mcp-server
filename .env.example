# =============================================================================
# ELO connection
# =============================================================================

# ELO IX REST API base URL (without trailing slash).
# Example: https://elo.example.com/ix-INSTANCE
ELO_BASE_URL=

# Link-service base URL used to build human-clickable document/folder links.
# Set this to whatever URL prefix routes browsers to a document view when
# `/<objId>` is appended. Verify empirically: open a document in the web
# client, copy the URL prefix.
ELO_WEBCLIENT_URL=

# Technical user credentials (read-only role recommended).
# Wrap values in single quotes if they contain `#`, `$`, spaces, or other
# characters that dotenv would otherwise interpret.
ELO_USERNAME=
ELO_PASSWORD=

# Optional: separate HTTP Basic Auth credentials for a reverse proxy in front
# of IX (some deployments require Basic Auth on every path except /login).
# Defaults to ELO_USERNAME / ELO_PASSWORD if unset.
# ELO_BASIC_AUTH_USER=
# ELO_BASIC_AUTH_PASS=

# ELO ClientInfo defaults (sent on every login).
ELO_LANGUAGE=en
ELO_COUNTRY=US
ELO_TIMEZONE=UTC

# Name of the ELO index field that holds the project number on your masks.
# Default `PRJ_NO` matches the ELO Solutions standard project mask. Override
# for custom mask designs.
ELO_PROJECT_NUMBER_FIELD=PRJ_NO

# =============================================================================
# MCP transport
# =============================================================================

# Transport mode:
#   stdio: local subprocess (Claude Desktop). Default.
#   http : Streamable HTTP transport for remote hosting (Easypanel, etc.).
#          When set to http, MCP_SHARED_SECRET MUST be defined.
MCP_TRANSPORT=stdio

# HTTP transport bind address and port.
MCP_HTTP_HOST=0.0.0.0
MCP_HTTP_PORT=3000

# Shared secret for Bearer-token auth on the HTTP transport.
# Required when MCP_TRANSPORT=http. Generate with:
#   node -e "console.log(require('crypto').randomBytes(32).toString('base64url'))"
# MCP_SHARED_SECRET=

# =============================================================================
# Logging
# =============================================================================

# pino log level: trace | debug | info | warn | error | fatal
LOG_LEVEL=info
