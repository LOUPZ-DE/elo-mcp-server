{
  "name": "elo-mcp-server",
  "version": "0.1.0",
  "description": "Read-only Model Context Protocol (MCP) server for the ELO Digital Office document management system. Exposes search, metadata, document links, and project-folder lookups to LLM agents via stdio and Streamable HTTP transports.",
  "type": "module",
  "bin": {
    "elo-mcp-server": "./dist/index.js"
  },
  "main": "./dist/index.js",
  "files": [
    "dist",
    "README.md",
    ".env.example"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/LOUPZ-DE/elo-mcp-server.git"
  },
  "bugs": {
    "url": "https://github.com/LOUPZ-DE/elo-mcp-server/issues"
  },
  "homepage": "https://github.com/LOUPZ-DE/elo-mcp-server#readme",
  "author": "Loupz Engineering GmbH",
  "license": "CC-BY-NC-4.0",
  "keywords": [
    "mcp",
    "mcp-server",
    "model-context-protocol",
    "elo",
    "elo-digital-office",
    "document-management",
    "claude",
    "claude-desktop",
    "openai",
    "open-webui",
    "n8n",
    "notion",
    "typescript",
    "nodejs",
    "easypanel"
  ],
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "dev": "tsx src/index.ts",
    "test:login": "tsx scripts/test-login.ts",
    "inspect": "npx @modelcontextprotocol/inspector node dist/index.js",
    "typecheck": "tsc --noEmit"
  },
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.0.0",
    "axios": "^1.7.0",
    "dotenv": "^16.4.5",
    "express": "^4.21.0",
    "pino": "^9.5.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/node": "^22.7.0",
    "pino-pretty": "^11.3.0",
    "tsx": "^4.19.0",
    "typescript": "^5.6.0"
  }
}
